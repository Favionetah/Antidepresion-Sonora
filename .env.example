# Spotify API Credentials
# Obtén estos valores desde https://developer.spotify.com/dashboard
# Crea una aplicación y ve a "Settings" > "Basic Information"
SPOTIPY_CLIENT_ID=tu_client_id_aqui
SPOTIPY_CLIENT_SECRET=tu_client_secret_aqui

# Para desarrollo local usa http://localhost:8888/callback
# En el Dashboard de Spotify, agrega esta URL en "Redirect URIs"
SPOTIPY_REDIRECT_URI=http://localhost:8888/callback

# Telegram Bot Token
# Obténlo de @BotFather en Telegram: https://t.me/botfather
# Usa el comando /newbot y sigue las instrucciones
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui

# Configuración regional (opcional)
SPOTIFY_MARKET=MX
OAUTH_HOST=localhost
OAUTH_PORT=8888
